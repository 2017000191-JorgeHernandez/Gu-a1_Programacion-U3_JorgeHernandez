Algoritmo Actividad1_Leccion16
	Definir colores Como Cadena
	
	Dimension colores[8]
	
	Colores[1] <- "Negro"
	Colores[2] <- "Morado"
	Colores[3] <- "Cafe"
	Colores[4] <- "Rojo"
	Colores[5] <- "Amarillo"
	Colores[6] <- "Azul"
	Colores[7] <- "Verde"
	Colores[8] <- "Anaranjado"
	
	Escribir "Los colores del arreglo son: "
	Para i <- 1 Hasta  8 Hacer
		Escribir "Colores[", i, "] = ", colores[i]
	FinPara
FinAlgoritmo
